# ZIA Trader Environment Configuration
DATABASE_URL=sqlite:///./data/zia_trader.db
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=replace-with-a-secure-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Trading
SYMBOLS=["BTC/USDT","ETH/USDT","SOL/USDT"]
TIMEFRAME=1h
MAX_RISK_PER_TRADE=0.02
MIN_CONFIDENCE_THRESHOLD=0.7
PRICE_CHANGE_THRESHOLD=0.001
TRADING_LOOP_INTERVAL=5
ERROR_RETRY_INTERVAL=10

# AI Models
TRANSFORMER_INPUT_DIM=10
TRANSFORMER_D_MODEL=64
TRANSFORMER_NHEAD=4
TRANSFORMER_NUM_ENCODER_LAYERS=2
TRANSFORMER_SEQ_LEN=30

LSTM_INPUT_DIM=10
LSTM_HIDDEN_DIM=128
LSTM_NUM_LAYERS=2
LSTM_OUTPUT_DIM=1
LSTM_SEQ_LEN=30

# Risk Engine
DAILY_LOSS_LIMIT_PERCENT=0.05
WEEKLY_LOSS_LIMIT_PERCENT=0.10
MONTHLY_LOSS_LIMIT_PERCENT=0.15
KELLY_FRACTION=0.5
ATR_PERIOD=14
VOLATILITY_MULTIPLIER=1.5
MAX_EXPOSURE_PER_SYMBOL=0.10
MAX_TOTAL_EXPOSURE=0.30
CORRELATION_THRESHOLD=0.8

# Whale Detector
WHALE_ACTIVITY_THRESHOLD=0.05
WHALE_VOLUME_THRESHOLD_MULTIPLIER=5.0
WHALE_ACTIVITY_SNIPER_THRESHOLD=0.8

# Sniper Engine
SNIPER_VOLATILITY_THRESHOLD=0.02
SNIPER_TIMEFRAME=1m
SNIPER_TRADE_QUANTITY=0.001
SNIPER_PRICE_CACHE_EXPIRE=60
SNIPER_CYCLE_INTERVAL_SECONDS=1

# Observability
PROMETHEUS_PORT=8001
OTEL_SERVICE_NAME=zia-trader

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_INTERVAL=60
