{
  "dashboard": {
    "id": null,
    "title": "RoboTrader 2.0 - Overview",
    "tags": ["robotrader", "trading", "overview"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"robotrader-api\"}",
            "legendFormat": "API Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "DOWN"}}, "type": "value"},
              {"options": {"1": {"text": "UP"}}, "type": "value"}
            ]
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Total Trades Today",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(robotrader_trades_total[24h])",
            "legendFormat": "Trades"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Portfolio Value",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(robotrader_portfolio_value)",
            "legendFormat": "Total Value"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Active Positions",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(robotrader_positions_count)",
            "legendFormat": "Positions"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Trading Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(robotrader_trades_total{status=\"executed\"}[5m])",
            "legendFormat": "Successful Trades/min"
          },
          {
            "expr": "rate(robotrader_trades_total{status=\"failed\"}[5m])",
            "legendFormat": "Failed Trades/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "P&L Distribution",
        "type": "histogram",
        "targets": [
          {
            "expr": "robotrader_trade_pnl",
            "legendFormat": "P&L"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "AI Model Confidence",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, robotrader_ai_confidence)",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.50, robotrader_ai_confidence)",
            "legendFormat": "Median"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "API Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(robotrader_api_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 9,
        "title": "System Resources",
        "type": "timeseries",
        "targets": [
          {
            "expr": "robotrader_cpu_usage_percent",
            "legendFormat": "CPU Usage %"
          },
          {
            "expr": "robotrader_memory_usage_bytes / 1024 / 1024 / 1024",
            "legendFormat": "Memory Usage GB"
          },
          {
            "expr": "robotrader_disk_usage_percent",
            "legendFormat": "Disk Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percent"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 10,
        "title": "WebSocket Connections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "robotrader_websocket_connections",
            "legendFormat": "Active Connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 11,
        "title": "Market Data Latency",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, robotrader_market_data_latency_seconds)",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.50, robotrader_market_data_latency_seconds)",
            "legendFormat": "Median"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 12,
        "title": "Risk Violations",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(robotrader_risk_violations_total[5m])",
            "legendFormat": "{{type}} - {{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 30,
    "version": 1
  }
}

