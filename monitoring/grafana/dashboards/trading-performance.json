{
  "dashboard": {
    "id": null,
    "title": "RoboTrader 2.0 - Trading Performance",
    "tags": ["robotrader", "trading", "performance"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Win Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(robotrader_trades_total{status=\"executed\",pnl=\"positive\"}[24h]) / rate(robotrader_trades_total{status=\"executed\"}[24h]) * 100",
            "legendFormat": "Win Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 70}
              ]
            },
            "unit": "percent"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Total P&L Today",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(robotrader_trade_pnl_sum[24h]))",
            "legendFormat": "P&L"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": -1000},
                {"color": "yellow", "value": 0},
                {"color": "green", "value": 100}
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Sharpe Ratio",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(robotrader_sharpe_ratio[24h])",
            "legendFormat": "Sharpe Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 2}
              ]
            },
            "unit": "short",
            "decimals": 2
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Max Drawdown",
        "type": "stat",
        "targets": [
          {
            "expr": "max(robotrader_drawdown_current)",
            "legendFormat": "Max Drawdown"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            },
            "unit": "percent"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Cumulative P&L",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(robotrader_trade_pnl_sum)",
            "legendFormat": "Cumulative P&L"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Trades by Symbol",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (symbol) (increase(robotrader_trades_total[24h]))",
            "legendFormat": "{{symbol}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "P&L by Symbol",
        "type": "barchart",
        "targets": [
          {
            "expr": "sum by (symbol) (increase(robotrader_trade_pnl_sum[24h]))",
            "legendFormat": "{{symbol}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 8,
        "title": "Trade Execution Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, robotrader_trade_execution_duration_seconds)",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.50, robotrader_trade_execution_duration_seconds)",
            "legendFormat": "Median"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 9,
        "title": "Position Sizes",
        "type": "timeseries",
        "targets": [
          {
            "expr": "robotrader_position_size by (symbol)",
            "legendFormat": "{{symbol}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 10,
        "title": "AI Model Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "avg by (model) (robotrader_ai_confidence)",
            "legendFormat": "{{model}} Confidence"
          },
          {
            "expr": "rate(robotrader_ai_predictions_total[5m]) by (model)",
            "legendFormat": "{{model}} Predictions/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 11,
        "title": "Risk Metrics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "robotrader_var_95",
            "legendFormat": "VaR 95%"
          },
          {
            "expr": "robotrader_expected_shortfall",
            "legendFormat": "Expected Shortfall"
          },
          {
            "expr": "robotrader_portfolio_volatility",
            "legendFormat": "Portfolio Volatility"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percent"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      },
      {
        "id": 12,
        "title": "Trade Distribution by Hour",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum by (hour) (increase(robotrader_trades_total[1h]))",
            "legendFormat": "Trades"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "spectrum"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40}
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 30,
    "version": 1
  }
}

